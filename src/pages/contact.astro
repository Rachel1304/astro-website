---
import Layout from '../layouts/Layout.astro'
---

<Layout>
  <div class="min-h-[60vh] w-full flex items-center justify-center p-4">
    <div
      class="flex flex-col gap-20 p-10 items-between justify-center text-center w-full max-w-4xl"
    >
      <div class="flex flex-col items-start">
        <h2 class="mb-0">Dire</h2>
        <h1 class="mt-0 mb-0">Bonjour</h1>
        <div
          class="h-1 w-full max-w-4xl bg-[var(--color-blue)] mx-auto my-10 rounded-full"
        >
        </div>
        <div
          class="flex flex-col md:flex-row items-center justify-start gap-4 md:gap-6 w-full"
        >
          <a
            href="sms:+33642049542"
            class="w-full md:w-auto bg-[var(--color-darkblue)] text-white px-4 md:px-6 py-2 rounded-full font-semibold hover:translate-x-2 transition-all"
          >
            Écrire un message
          </a>

          <a
            href="mailto:rachel.bastie@outlook.fr"
            class="w-full md:w-auto bg-[var(--color-red)] text-white px-4 md:px-6 py-2 rounded-full font-semibold hover:translate-x-2 transition-all"
          >
            Envoyer un email
          </a>
        </div>
      </div>

      <div>
        <div class="flex justify-between">
          <p>Téléphone</p>
          <a
            href="tel:+33642049542"
            class="text-darkblue font-semibold hover:text-[var(--color-blue)] no-underline"
          >
            06.42.04.95.42
          </a>
        </div>
        <div class="flex justify-between">
          <p>Mail</p>
          <a
            href="mailto:rachel.bastie@outlook.fr"
            class="text-darkblue font-semibold hover:text-[var(--color-blue)] no-underline"
          >
            rachel.bastie@outlook.fr
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>
