---
import Footer from '../components/Footer.astro'
import Header from '../components/Header.astro'
import '../styles/global.css'
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta
			name="viewport"
			content="width=device-width"
		/>
		<link
			rel="icon"
			type="image/svg+xml"
			href="/favicon.svg"
		/>
		<link
			rel="icon"
			href="/favicon.ico"
		/>
		<link
			href="https://fonts.cdnfonts.com/css/neue-haas-grotesk-display-pro"
			rel="stylesheet"
		/>
		<link
			href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;700;1,400;700&display=swap"
			rel="stylesheet"
		/>

		<meta
			name="generator"
			content={Astro.generator}
		/>
		<title>Rachel Bastié</title>
	</head>
	<body class="bg-white overflow-x-hidden min-h-screen flex flex-col">
		<Header />
		<main class="w-full pt-10 flex-grow">
			<slot />
		</main>

		<Footer />
	</body>
</html>
