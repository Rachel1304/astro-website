---
// On importe le composant Image d'Astro pour l'optimisation
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'

interface Props {
  src: ImageMetadata
  alt: string
  href: string
  texte: string
}
---

<a
  href={Astro.props.href}
  target="_blank"
  class="flex gap-4 items-center self-end"
>
  <p class="flex text-white text-sm text-semibold">{Astro.props.texte}</p>
  <Image
    src={Astro.props.src}
    alt={Astro.props.alt}
    class="w-8 h-8 transition-transform duration-300 hover:scale-120"
  />
</a>
