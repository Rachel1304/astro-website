    d="M75.4,26.61c1.23,3.12-2.55,7.41-2.55,7.41,0,0,7.72,2.2,13.51,2.2,0-9.08,18.71-13.59,18.71-13.59h0v-5.76h0v-3.27h0s-18.71-4.52-18.71-13.59c-5.79,0-13.51,2.2-13.51,2.2,0,0,.02.02.04.05.42.49,3.66,4.44,2.51,7.35-1.07,2.73-8.51,1.81-10.36,1.53-.26-.04-.42-.06-.42-.06v-2.15h0v-.06c0-.14-.01-.27-.04-.4,0-.04-.02-.08-.03-.12-.02-.09-.04-.17-.07-.26-.02-.05-.04-.09-.05-.14-.03-.07-.06-.15-.1-.22-.02-.04-.05-.09-.08-.13-.02-.03-.04-.06-.06-.08v.05c-.43-.63-1.16-1.04-1.97-1.04-1.23,0-2.23.93-2.37,2.11v5.12H0v4.35h0v.14h0v4.18h59.86v5.29c.14,1.19,1.14,2.11,2.37,2.11,1.32,0,2.4-1.07,2.4-2.4v-.06h0v-2.22s9.54-1.65,10.77,1.47Z"
