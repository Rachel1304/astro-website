---
import Arrow from './Arrow.astro'

interface Props {
  texte: string
  lien: string
}
---

<a
  href={Astro.props.lien}
  target="_self"
  class="flex font-semibold text-sm gap-2 text-darkblue transition-all duration-300 ease-in-out
   hover:-translate-x-2"
>
  <Arrow
    foreground="var(--color-black)"
    variant="rotate"
  />
  {Astro.props.texte}
</a>
